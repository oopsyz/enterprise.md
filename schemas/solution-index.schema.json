{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/solution-index.schema.json",
  "title": "solution-index.yml",
  "type": "object",
  "required": [
    "solution_key",
    "owners",
    "entrypoints"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Deprecated alias for spec_name + spec_version; accepted during 1.x. Writers MUST emit spec_name/spec_version."
    },
    "solution_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "owners": {
      "type": "object",
      "required": [
        "solution_architect"
      ],
      "properties": {
        "solution_architect": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "solution_md"
      ],
      "properties": {
        "solution_md": {
          "type": "string",
          "minLength": 1
        },
        "agents_md": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain_id"
        ],
        "properties": {
          "domain_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "repos": {
      "type": "array"
    },
    "spec_name": {
      "type": "string",
      "const": "solution-index"
    },
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Full MAJOR.MINOR.PATCH semantic version."
    }
  },
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "spec_name",
        "spec_version"
      ]
    },
    {
      "required": [
        "version"
      ]
    }
  ]
}
