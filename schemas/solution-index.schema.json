{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/solution-index.schema.json",
  "title": "solution-index.yml",
  "type": "object",
  "required": ["version", "solution_key", "owners", "entrypoints"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "solution_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "owners": {
      "type": "object",
      "required": ["solution_architect"],
      "properties": {
        "solution_architect": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "entrypoints": {
      "type": "object",
      "required": ["solution_md"],
      "properties": {
        "solution_md": {
          "type": "string",
          "minLength": 1
        },
        "agents_md": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "domains": {
      "type": "array"
    },
    "repos": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
