{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/domain-registry.schema.json",
  "title": "domain-registry.yml",
  "type": "object",
  "required": ["spec_name", "spec_version", "domains"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Deprecated field. A bare version no longer satisfies the header contract; emit spec_name and spec_version. Retained only so pre-1.x files still parse."
    },
    "spec_name": {
      "type": "string",
      "const": "domain-registry"
    },
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Full MAJOR.MINOR.PATCH semantic version."
    },
    "enterprise_id": {
      "type": "string",
      "minLength": 1
    },
    "domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "spec_version": {
            "pattern": "^2\\."
          }
        },
        "required": ["spec_version"]
      },
      "then": {
        "properties": {
          "domains": {
            "items": {
              "$ref": "#/$defs/domainV2"
            }
          }
        }
      },
      "else": {
        "properties": {
          "domains": {
            "items": {
              "$ref": "#/$defs/domainV1"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "approved",
        "ready",
        "in_progress",
        "paused",
        "completed",
        "archived",
        "deprecated",
        "inactive"
      ]
    },
    "capability": {
      "type": "object",
      "required": ["capability_id", "name"],
      "properties": {
        "capability_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "standardsProvider": {
      "type": "object",
      "required": ["entrypoint", "pattern_index_ref"],
      "properties": {
        "enterprise_default": {
          "type": "boolean",
          "default": false
        },
        "entrypoint": {
          "$ref": "#/$defs/safeRelativePath"
        },
        "pattern_index_ref": {
          "$ref": "#/$defs/safeRelativePath"
        }
      },
      "additionalProperties": false
    },
    "domain": {
      "type": "object",
      "required": ["domain_id", "name", "owner", "status"],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_repo_url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "domain_entrypoint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_git_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "default_agent": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Default owning agent for this domain. Must be a DA domain specialist, not only a cross-cutting reviewer."
        },
        "fallback_agent": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "Fallback owning agent for this domain when no finer specialist is available. Must be a DA domain specialist."
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "standards": {
          "type": "object",
          "properties": {
            "frameworks": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "policies": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          },
          "additionalProperties": true
        },
        "target_state": {
          "type": "object",
          "properties": {
            "principles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "constraints": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "domainV1": {
      "allOf": [
        {
          "$ref": "#/$defs/domain"
        },
        {
          "not": {
            "anyOf": [
              {"required": ["entry_type"]},
              {"required": ["standards_provider"]}
            ]
          }
        },
        {
          "if": {"required": ["domain_repo_url"]},
          "then": {"required": ["domain_entrypoint", "domain_git_ref"]}
        }
      ]
    },
    "domainV2": {
      "allOf": [
        {
          "$ref": "#/$defs/domain"
        },
        {
          "required": ["entry_type"],
          "properties": {
            "entry_type": {
              "enum": ["domain", "standards_provider", "both"]
            },
            "standards_provider": {
              "$ref": "#/$defs/standardsProvider"
            }
          }
        },
        {
          "if": {
            "properties": {"entry_type": {"const": "domain"}},
            "required": ["entry_type"]
          },
          "then": {
            "not": {"required": ["standards_provider"]},
            "allOf": [
              {
                "if": {"required": ["domain_repo_url"]},
                "then": {"required": ["domain_entrypoint", "domain_git_ref"]}
              }
            ]
          }
        },
        {
          "if": {
            "properties": {"entry_type": {"const": "standards_provider"}},
            "required": ["entry_type"]
          },
          "then": {
            "required": ["domain_repo_url", "domain_git_ref", "standards_provider"],
            "not": {"required": ["domain_entrypoint"]}
          }
        },
        {
          "if": {
            "properties": {"entry_type": {"const": "both"}},
            "required": ["entry_type"]
          },
          "then": {
            "required": ["domain_repo_url", "domain_entrypoint", "domain_git_ref", "standards_provider"]
          }
        }
      ]
    }
  },
  "additionalProperties": true
}
