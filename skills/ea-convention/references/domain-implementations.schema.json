{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/domain-implementations.schema.json",
  "title": "domain-implementations.yml",
  "type": "object",
  "required": ["spec_name", "spec_version", "implementations"],
  "properties": {
    "spec_name": {
      "type": "string",
      "const": "multi-scale-routing"
    },
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "implementations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/implementation"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "approved",
        "ready",
        "in_progress",
        "paused",
        "completed",
        "archived",
        "deprecated",
        "inactive"
      ]
    },
    "repo": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri",
            "minLength": 1
          }
        },
        "entrypoint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "git_ref": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "implementation": {
      "type": "object",
      "required": ["implementation_id", "status", "repo"],
      "properties": {
        "implementation_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "repo": {
          "$ref": "#/$defs/repo"
        },
        "valid_from": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "valid_to": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "replaced_by": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "workstream_id": {
          "type": ["string", "null"]
        },
        "initiative_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owners": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "oda_component_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tmfc_component_id": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
