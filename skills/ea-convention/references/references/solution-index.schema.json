{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "solution-index.schema.json",
  "title": "Solution Index",
  "type": "object",
  "required": ["version", "solution_key", "owners", "entrypoints"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "solution_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "display_name": { "type": "string" },
    "description": { "type": "string" },
    "owners": {
      "type": "object",
      "required": ["solution_architect"],
      "additionalProperties": true,
      "properties": {
        "solution_architect": { "type": "string" }
      }
    },
    "entrypoints": {
      "type": "object",
      "required": ["solution_md"],
      "additionalProperties": true,
      "properties": {
        "solution_md": { "type": "string" },
        "agents_md": { "type": "string" }
      }
    },
    "domains": { "type": "array" },
    "repos": { "type": "array" }
  }
}
