{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "domain-implementations.schema.json",
  "title": "Domain Implementations",
  "type": "object",
  "required": ["spec_name", "spec_version", "implementations"],
  "additionalProperties": false,
  "properties": {
    "spec_name": { "type": "string" },
    "spec_version": { "type": "string" },
    "implementations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["implementation_id", "status", "repo", "owners"],
        "additionalProperties": true,
        "properties": {
          "implementation_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "status": { "type": "string", "enum": ["active", "inactive", "deprecated", "archived"] },
          "repo": {
            "type": "object",
            "required": ["paths"],
            "additionalProperties": false,
            "properties": {
              "url": { "type": "string" },
              "paths": { "type": "array", "items": { "type": "string" } },
              "entrypoint": { "type": "string" },
              "git_ref": { "type": "string" }
            }
          },
          "owners": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
