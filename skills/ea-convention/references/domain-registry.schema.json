{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/domain-registry.schema.json",
  "title": "domain-registry.yml",
  "type": "object",
  "required": ["version", "domains"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "enterprise_id": {
      "type": "string",
      "minLength": 1
    },
    "domains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/domain"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "approved",
        "ready",
        "in_progress",
        "paused",
        "completed",
        "archived",
        "deprecated",
        "inactive"
      ]
    },
    "capability": {
      "type": "object",
      "required": ["capability_id", "name"],
      "properties": {
        "capability_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "domain": {
      "type": "object",
      "required": ["domain_id", "name", "owner", "status"],
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_repo_url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "domain_entrypoint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_git_ref": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability"
          }
        },
        "standards": {
          "type": "object",
          "properties": {
            "frameworks": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "policies": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          },
          "additionalProperties": true
        },
        "target_state": {
          "type": "object",
          "properties": {
            "principles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            },
            "constraints": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["domain_repo_url"]
          },
          "then": {
            "required": ["domain_entrypoint", "domain_git_ref"]
          }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
