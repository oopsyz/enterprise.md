{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/enterprise.md/schemas/domain-roadmap.schema.json",
  "title": "domain-roadmap.yml",
  "type": "object",
  "required": ["spec_name", "spec_version", "domain_id", "items"],
  "properties": {
    "spec_name": {
      "type": "string",
      "const": "domain-roadmap"
    },
    "spec_version": {
      "type": "string",
      "minLength": 1
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/roadmapItem"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "roadmapItem": {
      "type": "object",
      "required": ["roadmap_item_id", "workstream_ids", "implementation_ids", "status"],
      "properties": {
        "roadmap_item_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "workstream_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "minItems": 1
        },
        "implementation_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "minItems": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "done"]
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "milestone": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
