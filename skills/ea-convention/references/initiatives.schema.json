{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "initiatives.schema.json",
  "title": "Initiatives",
  "type": "object",
  "required": ["version", "initiatives"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "initiatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["initiative_id", "name", "status", "owner", "solution_repo_url", "solution_entrypoint"],
        "additionalProperties": true,
        "properties": {
          "initiative_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "inactive", "deprecated", "archived"] },
          "owner": { "type": "string" },
          "solution_repo_url": { "type": "string" },
          "solution_entrypoint": { "type": "string" }
        }
      }
    }
  }
}
